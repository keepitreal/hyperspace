# Copy this file to `.env` (gitignored) and fill in real values, OR
# export these in your shell. The CLI reads them from process.env.

# --- Telegram (optional) ---
# Set BOTH variables to enable Telegram alerts. Leave empty / unset to disable.
# Setup:
#   1. Open Telegram, talk to @BotFather, run /newbot, follow prompts.
#      Save the bot token it returns.
#   2. Talk to your new bot once (send any message) so it can DM you.
#   3. In a browser, hit:
#        https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#      Look for "chat":{"id": <NUMBER>, ...} in the JSON. That's your chat_id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Alert kind filter (optional) ---
# Comma-separated list of alert kinds to send to remote notifiers (Telegram).
# Console always shows everything regardless of this filter.
# Valid kinds: BREAKOUT, RETEST_START, CONFIRMED, INVALIDATED, EXPIRED
# Default if unset: BREAKOUT,RETEST_START,CONFIRMED
# HYPERSPACE_ALERT_KINDS=BREAKOUT,RETEST_START,CONFIRMED
