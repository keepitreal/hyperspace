{
  "name": "hyperspace",
  "version": "0.1.0",
  "private": true,
  "description": "Read-only Hyperliquid candle monitor that flags breakout-and-retest setups against auto-detected support and resistance levels.",
  "type": "module",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "check:telegram": "tsx scripts/check-telegram.ts",
    "backtest": "tsx strategies/run.ts",
    "analyst": "tsx analyst/run.ts",
    "test": "tsx --test analyst/*.test.ts analyst/indicators/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.99.0",
    "tsx": "^4.19.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "typescript": "^5.6.3"
  }
}
