{
  "stateDir": "/data",
  "defaults": {
    "lookback": 300,
    "pollMs": 5000,
    "pivotWindow": 5,
    "clusterBps": 25,
    "breakBps": 10,
    "retestBps": 15,
    "retestBars": 20,
    "maxLevels": 8,
    "maxReplayBars": 50,
    "volatilityThresholdPct": 0.5
  },
  "symbols": [
    {
      "coin": "ETH",
      "interval": "5m",
      "alerts": [
        "BREAKOUT",
        "RETEST_START",
        "CONFIRMED",
        "INVALIDATED",
        "EXPIRED",
        "RSI_OVERBOUGHT",
        "RSI_OVERSOLD",
        "VOLATILITY_SPIKE"
      ]
    },
    {
      "coin": "ETH",
      "interval": "15m",
      "pollMs": 30000,
      "alerts": ["VOLATILITY_SPIKE"]
    },
    {
      "coin": "ETH",
      "interval": "30m",
      "pollMs": 60000,
      "alerts": ["VOLATILITY_SPIKE"]
    },
    {
      "coin": "ETH",
      "interval": "1h",
      "pollMs": 120000,
      "alerts": ["VOLATILITY_SPIKE"]
    }
  ]
